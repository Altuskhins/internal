CLIENT_SOURCE = r'''import ctypes
import json
import os

try:
    from org.telegram.messenger import ApplicationLoader
except Exception:
    ApplicationLoader = None


def default_lib_path():
    if ApplicationLoader is not None:
        base = ApplicationLoader.applicationContext.getFilesDir().getAbsolutePath()
        return os.path.join(base, "yggstack_modules", "libygg_stack.so")
    return os.path.join("yggstack_modules", "libygg_stack.so")


class YggStackClient:
    def __init__(self, lib_path=None):
        self.lib_path = str(lib_path or default_lib_path())
        self.lib = ctypes.CDLL(self.lib_path, mode=2 | 0x100)
        self.lib.StartYggStack.argtypes = [ctypes.c_char_p]
        self.lib.StartYggStack.restype = ctypes.c_void_p
        self.lib.GetYggStackStatus.argtypes = []
        self.lib.GetYggStackStatus.restype = ctypes.c_void_p
        start_core = getattr(self.lib, "StartCore", None)
        if start_core is not None:
            start_core.argtypes = [ctypes.c_char_p]
            start_core.restype = ctypes.c_void_p
        self.lib.OpenYggTcpForward.argtypes = [ctypes.c_char_p]
        self.lib.OpenYggTcpForward.restype = ctypes.c_void_p
        self.lib.CloseYggTcpForward.argtypes = [ctypes.c_char_p]
        self.lib.CloseYggTcpForward.restype = ctypes.c_int
        self.lib.ListYggTcpForwards.argtypes = []
        self.lib.ListYggTcpForwards.restype = ctypes.c_void_p
        self.libc = ctypes.CDLL("libc.so")
        self.libc.free.argtypes = [ctypes.c_void_p]
        self.libc.free.restype = None
        self.free_c_string = getattr(self.lib, "FreeCString", None)
        if self.free_c_string is not None:
            self.free_c_string.argtypes = [ctypes.c_void_p]
            self.free_c_string.restype = None

    def _free_result_ptr(self, ptr):
        if not ptr:
            return
        if self.free_c_string is not None:
            self.free_c_string(ptr)
            return
        self.libc.free(ptr)

    def _json_call(self, func_name, payload=None):
        ptr = None
        try:
            func = getattr(self.lib, func_name)
            if payload is None:
                ptr = func()
            else:
                data = json.dumps(payload, ensure_ascii=False, separators=(",", ":")).encode("utf-8")
                ptr = func(data)
            if not ptr:
                return {"ok": False, "message": "empty native response"}
            raw = ctypes.cast(ptr, ctypes.c_char_p).value or b"{}"
            return json.loads(raw.decode("utf-8", errors="ignore"))
        finally:
            if ptr:
                self._free_result_ptr(ptr)

    def status(self):
        return self._json_call("GetYggStackStatus")

    def open_tcp_forward(self, target_host, target_port, listen_host="127.0.0.1", listen_port=0, forward_id=""):
        return self._json_call("OpenYggTcpForward", {
            "id": str(forward_id or ""),
            "listen_addr": "%s:%d" % (listen_host, int(listen_port or 0)),
            "target_host": str(target_host or ""),
            "target_port": int(target_port or 0),
        })

    def close_tcp_forward(self, forward_id):
        return int(self.lib.CloseYggTcpForward(str(forward_id or "").encode("utf-8")))

    def list_tcp_forwards(self):
        return self._json_call("ListYggTcpForwards")
'''


def _safe_int(value, default=0):
    try:
        return int(value)
    except Exception:
        return int(default)


def _extract_peer_uris(text):
    matches = re.findall(r"(?:tcp|tls|quic|ws|wss)://[^\s`\"'<>]+", str(text or ""), re.IGNORECASE)
    scheme_rank = {
        "tls://": 0,
        "tcp://": 1,
        "quic://": 2,
        "wss://": 3,
        "ws://": 4,
    }
    items = []
    seen = set()
    for idx, raw in enumerate(matches):
        uri = str(raw or "").strip().rstrip(".,)")
        low = uri.lower()
        if low in seen:
            continue
        seen.add(low)
        rank = 9
        for prefix, prefix_rank in scheme_rank.items():
            if low.startswith(prefix):
                rank = prefix_rank
                break
        items.append((rank, idx, uri))
    items.sort(key=lambda item: (item[0], item[1]))
    return [item[2] for item in items]


def _iter_nonempty_lines(text):
    for raw in str(text or "").splitlines():
        line = str(raw or "").strip()
        if (not line) or line.startswith("#"):
            continue
        yield line


def _dedupe_strings(items):
    result = []
    seen = set()
    for item in items or []:
        value = str(item or "").strip()
        if not value:
            continue
        key = value.lower()
        if key in seen:
            continue
        seen.add(key)
        result.append(value)
    return result


def _parse_custom_peers_text(text):
    peers = []
    for line in _iter_nonempty_lines(text):
        if "://" not in line:
            continue
        peers.append(line)
    return _dedupe_strings(peers)


def _download_text(url, timeout=12):
    req = urllib.request.Request(str(url), headers={"User-Agent": "YggStack/0.1"})
    ctx = ssl.create_default_context()
    with urllib.request.urlopen(req, timeout=float(timeout), context=ctx) as resp:
        data = resp.read()
    return data.decode("utf-8", errors="ignore")


class PluginLinker:
    def __init__(self):
        self.open_ext = None
        self.Info = None
        try:
            self.libdl = ctypes.CDLL("libdl.so")
            self.open_ext = self.libdl.android_dlopen_ext

            class Info(ctypes.Structure):
                _fields_ = [
                    ("flags", ctypes.c_uint64),
                    ("reserved_addr", ctypes.c_void_p),
                    ("reserved_size", ctypes.c_size_t),
                    ("relro_fd", ctypes.c_int),
                    ("library_fd", ctypes.c_int),
                    ("library_fd_offset", ctypes.c_uint64),
                    ("library_namespace", ctypes.c_void_p),
                ]

            self.Info = Info
            self.open_ext.argtypes = [ctypes.c_char_p, ctypes.c_int, ctypes.POINTER(self.Info)]
            self.open_ext.restype = ctypes.c_void_p
        except Exception:
            self.open_ext = None

    def load(self, path):
        try:
            target = str(path or "")
        except Exception:
            target = ""
        if not target:
            return None

        try:
            if self.open_ext and self.Info:
                fd = os.open(target, os.O_RDONLY)
                try:
                    info = self.Info(flags=0x10, library_fd=fd)
                    handle = self.open_ext(target.encode("utf-8"), 2 | 0x100, ctypes.byref(info))
                    if handle:
                        return ctypes.CDLL(target, handle=handle)
                finally:
                    try:
                        os.close(fd)
                    except Exception:
                        pass
        except Exception:
            pass

        try:
            return ctypes.CDLL(target, mode=2 | 0x100)
        except Exception:
            return None


class YggStackNative:
    def __init__(self, so_path):
        self._so_path = str(so_path or "")
        self.lib = None
        self.libc = None
        self.free_c_string = None
        self._init_native()

    def _init_native(self):
        try:
            lib = PluginLinker().load(self._so_path)
            if not lib:
                return
            lib.StartYggStack.argtypes = [ctypes.c_char_p]
            lib.StartYggStack.restype = ctypes.c_void_p
            start_core = getattr(lib, "StartCore", None)
            if start_core is not None:
                start_core.argtypes = [ctypes.c_char_p]
                start_core.restype = ctypes.c_void_p
            lib.StopYggStack.argtypes = []
            lib.StopYggStack.restype = ctypes.c_int
            stop_core = getattr(lib, "StopCore", None)
            if stop_core is not None:
                stop_core.argtypes = []
                stop_core.restype = None
            graceful_stop = getattr(lib, "StopYggStackGraceful", None)
            if graceful_stop is not None:
                graceful_stop.argtypes = [ctypes.c_int]
                graceful_stop.restype = ctypes.c_int
            lib.GetYggStackStatus.argtypes = []
            lib.GetYggStackStatus.restype = ctypes.c_void_p
            get_status = getattr(lib, "GetStatusJSON", None)
            if get_status is not None:
                get_status.argtypes = []
                get_status.restype = ctypes.c_void_p
            lib.OpenYggTcpForward.argtypes = [ctypes.c_char_p]
            lib.OpenYggTcpForward.restype = ctypes.c_void_p
            lib.CloseYggTcpForward.argtypes = [ctypes.c_char_p]
            lib.CloseYggTcpForward.restype = ctypes.c_int
            lib.ListYggTcpForwards.argtypes = []
            lib.ListYggTcpForwards.restype = ctypes.c_void_p
            addr_func = getattr(lib, "GetYggStackAddressForPublicKey", None)
            if addr_func is not None:
                addr_func.argtypes = [ctypes.c_char_p]
                addr_func.restype = ctypes.c_void_p
            free_func = getattr(lib, "FreeCString", None)
            if free_func is not None:
                free_func.argtypes = [ctypes.c_void_p]
                free_func.restype = None
                self.free_c_string = free_func
            self.lib = lib
            try:
                self.libc = ctypes.CDLL("libc.so")
                self.libc.free.argtypes = [ctypes.c_void_p]
                self.libc.free.restype = None
            except Exception:
                self.libc = None
        except Exception:
            self.lib = None

    def is_available(self):
        return self.lib is not None

    def _free_result_ptr(self, ptr):
        if not ptr:
            return
        try:
            if self.free_c_string:
                self.free_c_string(ptr)
                return
        except Exception:
            pass
        try:
            if self.libc:
                self.libc.free(ptr)
        except Exception:
            pass

    def _call_json(self, func_name, payload=None):
        if not self.lib:
            return {"ok": False, "message": "Ядро не загружено"}
        ptr = None
        try:
            func = getattr(self.lib, str(func_name))
            if payload is None:
                ptr = func()
            else:
                ptr = func(str(payload or "").encode("utf-8"))
            if not ptr:
                return {"ok": False, "message": "Пустой ответ ядра"}
            raw = ctypes.cast(ptr, ctypes.c_char_p).value
            text = raw.decode("utf-8", errors="ignore") if raw else ""
            data = json.loads(text) if text else {}
            return data if isinstance(data, dict) else {"ok": False, "message": "Неверный ответ ядра"}
        except Exception as exc:
            return {"ok": False, "message": str(exc)}
        finally:
            self._free_result_ptr(ptr)

    def start(self, config):
        return self._call_json("StartYggStack", json.dumps(config, ensure_ascii=False, separators=(",", ":")))

    def status(self):
        return self._call_json("GetYggStackStatus")

    def open_tcp_forward(self, config):
        return self._call_json("OpenYggTcpForward", json.dumps(config, ensure_ascii=False, separators=(",", ":")))

    def list_tcp_forwards(self):
        return self._call_json("ListYggTcpForwards")

    def close_tcp_forward(self, forward_id):
        if not self.lib:
            return -1
        try:
            return int(self.lib.CloseYggTcpForward(str(forward_id or "").encode("utf-8")))
        except Exception:
            return -1

    def stop(self, graceful_ms=DEFAULT_SHUTDOWN_WAIT_MS):
        if not self.lib:
            return
        try:
            graceful = getattr(self.lib, "StopYggStackGraceful", None)
            if graceful is not None:
                graceful(int(graceful_ms or DEFAULT_SHUTDOWN_WAIT_MS))
            else:
                self.lib.StopYggStack()
        except Exception:
            pass


class YggStackApi:
    def __init__(self, plugin):
        self._plugin = plugin

    def status(self):
        return self._plugin.stack_status()

    def ensure_running(self):
        return self._plugin.ensure_running(show_errors=False)

    def open_tcp_forward(self, target_host, target_port, listen_host=LOCAL_HOST, listen_port=0, forward_id=""):
        return self._plugin.open_tcp_forward(
            target_host=target_host,
            target_port=target_port,
            listen_host=listen_host,
            listen_port=listen_port,
            forward_id=forward_id,
            show_errors=False,
        )

    def close_tcp_forward(self, forward_id):
        return self._plugin.close_tcp_forward(forward_id)

    def list_tcp_forwards(self):
        return self._plugin._stack.list_tcp_forwards()


class YggStackPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self._active = False
        self._running = False
        self._start_lock = threading.Lock()
        self._start_in_progress = False
        self._worker_lock = threading.Lock()
        self._worker_busy = False
        self._modules_dir = "yggstack_modules"
        self._state_file = "yggstack_node.json"
        self._plugin_log_file = "yggstack_plugin.log"
        self._stack_log_file = "yggstack.log"
        self._stack = YggStackNative("")
        self._api = YggStackApi(self)
        self._peers_cache = []
        self._peers_updated_at = 0
        self._custom_peers_cache = {"raw": None, "parsed": []}
        self._last_status = {"ok": True, "running": False, "message": "idle"}

    def on_plugin_load(self):
        self._active = True
        self._init_paths()
        self._write_client_lib()
        self._publish_api()
        self._log_line("plugin load started")
        self._stack = YggStackNative("")
        self._peers_cache = self._load_json_setting("peer_cache", [])
        self._peers_updated_at = _safe_int(self.get_setting("peer_cache_ts", 0), 0)
        self._maybe_auto_update_stack_async()
        if bool(self.get_setting("enable_stack", False)):
            self._ensure_started_async(force_peer_refresh=False, show_errors=False)

    def on_plugin_unload(self):
        self._active = False
        self._log_line("plugin unload")
        self._unpublish_api()
        try:
            self._disconnect_stack()
        except Exception:
            pass

    def on_app_event(self, event):
        if event in (AppEvent.START, AppEvent.RESUME):
            if bool(self.get_setting("enable_stack", False)) and (not self._running) and (not self._start_in_progress):
                self._ensure_started_async(force_peer_refresh=False, show_errors=False)

    def _publish_api(self):
        try:
            self._api = YggStackApi(self)
            builtins.yggstack_api = self._api
            globals()["YGGSTACK_API"] = self._api
            self._log_line("api published")
        except Exception:
            self._log_line("api publish failed", exc=True)

    def _unpublish_api(self):
        try:
            if getattr(builtins, "yggstack_api", None) is self._api:
                delattr(builtins, "yggstack_api")
        except Exception:
            pass
        try:
            if globals().get("YGGSTACK_API") is self._api:
                del globals()["YGGSTACK_API"]
        except Exception:
            pass

    def _init_paths(self):
        try:
            ctx = ApplicationLoader.applicationContext
            base = ctx.getFilesDir().getAbsolutePath()
            self._modules_dir = os.path.join(base, "yggstack_modules")
            self._state_file = os.path.join(self._modules_dir, "yggstack_node.json")
            self._plugin_log_file = os.path.join(self._modules_dir, "yggstack_plugin.log")
            self._stack_log_file = os.path.join(self._modules_dir, "yggstack.log")
        except Exception:
            self._modules_dir = "yggstack_modules"
            self._state_file = os.path.join(self._modules_dir, "yggstack_node.json")
            self._plugin_log_file = os.path.join(self._modules_dir, "yggstack_plugin.log")
            self._stack_log_file = os.path.join(self._modules_dir, "yggstack.log")
        try:
            os.makedirs(self._modules_dir, exist_ok=True)
        except Exception:
            pass

    def _rotate_log_if_needed(self, path):
        try:
            if os.path.exists(path) and os.path.getsize(path) > int(LOG_FILE_MAX_BYTES):
                old_path = path + ".old"
                try:
                    if os.path.exists(old_path):
                        os.remove(old_path)
                except Exception:
                    pass
                os.replace(path, old_path)
        except Exception:
            pass

    def _log_line(self, message, exc=None):
        try:
            path = str(self._plugin_log_file or "yggstack_plugin.log")
            self._rotate_log_if_needed(path)
            stamp = time.strftime("%Y-%m-%d %H:%M:%S")
            text = "[%s] %s" % (stamp, str(message))
            if exc is True:
                text += "\n" + traceback.format_exc()
            elif exc:
                text += "\n%s\n%s" % (str(exc), traceback.format_exc())
            with open(path, "a", encoding="utf-8") as fp:
                fp.write(text + "\n")
        except Exception:
            pass

    def _copy_to_clipboard(self, label, value):
        try:
            from android.content import ClipData, Context

            ctx = ApplicationLoader.applicationContext
            clipboard = ctx.getSystemService(Context.CLIPBOARD_SERVICE)
            if clipboard is None:
                return False
            clip = ClipData.newPlainText(str(label or "YggStack"), str(value or ""))
            clipboard.setPrimaryClip(clip)
            return True
        except Exception as exc:
            self._log_line("clipboard copy failed", exc=exc)
            return False

    def _write_client_lib(self):
        try:
            path = os.path.join(self._modules_dir, "yggstack_client.py")
            with open(path, "w", encoding="utf-8") as fp:
                fp.write(CLIENT_SOURCE)
            return path
        except Exception as exc:
            self._log_line("write client lib failed", exc=exc)
            return ""

    def _copy_api_hint(self):
        client_path = self._write_client_lib()
        payload = "\n".join([
            "import sys",
            "sys.path.append(%r)" % str(self._modules_dir),
            "from yggstack_client import YggStackClient",
            "ys = YggStackClient()",
            "fwd = ys.open_tcp_forward('200:db8::1', 80)",
            "print(fwd)",
            "",
            "client_path = %r" % str(client_path),
        ])
        if self._copy_to_clipboard("YggStack API", payload):
            BulletinHelper.show_success("API скопирован")
        else:
            BulletinHelper.show_error("Не удалось скопировать")

    def _read_tail(self, path, limit=LOG_COPY_MAX_BYTES):
        try:
            if not path or not os.path.exists(path):
                return ""
            size = os.path.getsize(path)
            with open(path, "rb") as fp:
                if size > int(limit):
                    fp.seek(max(0, size - int(limit)))
                data = fp.read(int(limit))
            return data.decode("utf-8", errors="replace")
        except Exception:
            return ""

    def _copy_logs_to_clipboard(self):
        parts = [
            "=== yggstack_plugin.log ===\n%s" % (self._read_tail(self._plugin_log_file) or "empty or not found"),
            "=== yggstack.log ===\n%s" % (self._read_tail(self._stack_log_file) or "empty or not found"),
        ]
        if self._copy_to_clipboard("YggStack logs", "\n\n".join(parts)):
            BulletinHelper.show_success("Логи скопированы")
        else:
            BulletinHelper.show_error("Не удалось скопировать")

    def _load_json_setting(self, key, default):
        raw = self.get_setting(key, "")
        try:
            value = json.loads(raw) if raw else default
            return value if value is not None else default
        except Exception:
            return default

    def _save_json_setting(self, key, value):
        try:
            self.set_setting(key, json.dumps(value, ensure_ascii=False, separators=(",", ":")))
        except Exception:
            pass

    def _set_setting_value(self, key, value, reload_settings=False):
        try:
            self.set_setting(str(key or ""), value, reload_settings=bool(reload_settings))
            return True
        except Exception:
            pass
        try:
            self.set_setting(str(key or ""), value)
            return True
        except Exception:
            return False

    def _strip_ipv6_brackets(self, host):
        value = str(host or "").strip()
        if value.startswith("[") and value.endswith("]"):
            return value[1:-1].strip()
        return value

    def _is_local_host(self, host):
        value = str(host or "").strip().lower()
        return value in ("127.0.0.1", "localhost", "::1", "[::1]")

    def _is_ygg_ipv6_host(self, host):
        value = self._strip_ipv6_brackets(host)
        if ":" not in value:
            return False
        try:
            packed = socket.inet_pton(socket.AF_INET6, value)
            return bool(packed and packed[0] in (0x02, 0x03))
        except Exception:
            low = value.lower().lstrip("0")
            return bool(low.startswith("2") or low.startswith("3"))

    def _format_proxy_addr(self, cfg):
        host = str((cfg or {}).get("host", "") or "")
        port = _safe_int((cfg or {}).get("port", 0), 0)
        if ":" in host and not host.startswith("["):
            host = "[%s]" % host
        return "%s:%d" % (host, int(port))

    def _read_native_proxy_config(self):
        cfg = {
            "host": "",
            "port": 0,
            "username": "",
            "password": "",
            "secret": "",
            "enabled": False,
        }
        try:
            cfg["enabled"] = bool(SharedConfig.proxyEnabled)
        except Exception:
            pass
        current = None
        try:
            current = SharedConfig.currentProxy
        except Exception:
            current = None
        if current is not None:
            try:
                cfg["host"] = str(getattr(current, "address", "") or "")
            except Exception:
                pass
            try:
                cfg["port"] = int(getattr(current, "port", 0) or 0)
            except Exception:
                pass
            try:
                cfg["username"] = str(getattr(current, "username", "") or "")
            except Exception:
                pass
            try:
                cfg["password"] = str(getattr(current, "password", "") or "")
            except Exception:
                pass
            try:
                cfg["secret"] = str(getattr(current, "secret", "") or "")
            except Exception:
                pass

        if not cfg["host"] or int(cfg["port"] or 0) <= 0:
            try:
                prefs = MessagesController.getGlobalMainSettings()
                cfg["enabled"] = bool(prefs.getBoolean("proxy_enabled", bool(cfg["enabled"])))
                cfg["host"] = str(prefs.getString("proxy_ip", "") or "")
                cfg["port"] = int(prefs.getInt("proxy_port", 0) or 0)
                cfg["username"] = str(prefs.getString("proxy_user", "") or "")
                cfg["password"] = str(prefs.getString("proxy_pass", "") or "")
                cfg["secret"] = str(prefs.getString("proxy_secret", "") or "")
            except Exception:
                pass
        cfg["host"] = self._strip_ipv6_brackets(cfg.get("host", ""))
        cfg["port"] = int(cfg.get("port", 0) or 0)
        return cfg

    def _load_tg_bridge_target(self):
        data = self._load_json_setting("telegram_bridge_target", {})
        if not isinstance(data, dict):
            return {}
        data["host"] = self._strip_ipv6_brackets(data.get("host", ""))
        data["port"] = _safe_int(data.get("port", 0), 0)
        for key in ("username", "password", "secret"):
            data[key] = str(data.get(key, "") or "")
        return data

    def _save_tg_bridge_target(self, cfg):
        data = {
            "host": self._strip_ipv6_brackets((cfg or {}).get("host", "")),
            "port": _safe_int((cfg or {}).get("port", 0), 0),
            "username": str((cfg or {}).get("username", "") or ""),
            "password": str((cfg or {}).get("password", "") or ""),
            "secret": str((cfg or {}).get("secret", "") or ""),
        }
        self._save_json_setting("telegram_bridge_target", data)
        return data

    def _telegram_bridge_port(self):
        return _safe_int(self.get_setting("telegram_bridge_port", DEFAULT_TG_PROXY_BRIDGE_PORT), DEFAULT_TG_PROXY_BRIDGE_PORT)

    def _set_telegram_bridge_port(self, port):
        try:
            self.set_setting("telegram_bridge_port", str(int(port or 0)))
        except Exception:
            pass

    def _current_proxy_is_bridge_local(self):
        current = self._read_native_proxy_config()
        return bool(
            self._is_local_host(current.get("host", "")) and
            int(current.get("port", 0) or 0) == int(self._telegram_bridge_port() or 0)
        )

    def _target_for_tg_bridge(self):
        current = self._read_native_proxy_config()
        if self._is_ygg_ipv6_host(current.get("host", "")) and int(current.get("port", 0) or 0) > 0:
            return self._save_tg_bridge_target(current)
        if self._is_local_host(current.get("host", "")):
            saved = self._load_tg_bridge_target()
            if self._is_ygg_ipv6_host(saved.get("host", "")) and int(saved.get("port", 0) or 0) > 0:
                return saved
        saved = self._load_tg_bridge_target()
        if self._is_ygg_ipv6_host(saved.get("host", "")) and int(saved.get("port", 0) or 0) > 0:
            return saved
        return {}

    def _apply_native_proxy_config(self, cfg, server_override=None, port_override=None):
        target = dict(cfg or {})
        server = str(server_override if server_override is not None else target.get("host", "") or "")
        port = int(port_override if port_override is not None else target.get("port", 0) or 0)
        username = str(target.get("username", "") or "")
        password = str(target.get("password", "") or "")
        secret = str(target.get("secret", "") or "")
        if not server or port <= 0:
            return False

        pi = None
        try:
            from hook_utils import find_class
            proxy_cls = find_class("org.telegram.messenger.SharedConfig$ProxyInfo")
            if proxy_cls:
                ctor_getter = getattr(proxy_cls, "getConstructor", None) or getattr(proxy_cls, "getDeclaredConstructor", None)
                if ctor_getter:
                    ctor = ctor_getter(str, int, str, str, str)
                    candidate = ctor.newInstance(server, port, username, password, secret)
                    try:
                        pi = SharedConfig.addProxy(candidate)
                    except Exception:
                        pi = candidate
        except Exception:
            pi = None

        if not pi:
            try:
                candidate = SharedConfig.ProxyInfo(server, port, username, password, secret)
                pi = SharedConfig.addProxy(candidate)
            except Exception:
                pi = None

        if not pi:
            self._log_line("apply native proxy failed: no ProxyInfo")
            return False

        try:
            SharedConfig.currentProxy = pi
        except Exception:
            pass
        try:
            SharedConfig.proxyEnabled = True
        except Exception:
            pass
        try:
            if hasattr(SharedConfig, "saveProxyList"):
                SharedConfig.saveProxyList()
        except Exception:
            pass
        try:
            prefs = MessagesController.getGlobalMainSettings()
            editor = prefs.edit()
            editor.putBoolean("proxy_enabled", True)
            editor.putString("proxy_ip", server)
            editor.putString("proxy_user", username)
            editor.putString("proxy_pass", password)
            editor.putInt("proxy_port", int(port))
            editor.putString("proxy_secret", secret)
            editor.commit()
        except Exception:
            pass
        try:
            ConnectionsManager.setProxySettings(True, server, int(port), username, password, secret)
        except Exception:
            pass
        try:
            NotificationCenter.getGlobalInstance().postNotificationName(NotificationCenter.proxySettingsChanged)
        except Exception:
            pass
        return True

    def _listen_port_from_result(self, result, default_port):
        listen = str((result or {}).get("listen_addr", "") or "")
        try:
            return int(listen.rsplit(":", 1)[1])
        except Exception:
            return int(default_port or 0)

    def _bridge_native_proxy(self, show_errors=True, ensure_stack=True):
        if ensure_stack and not self.ensure_running(show_errors=show_errors):
            return False
        if not self._running:
            if show_errors:
                BulletinHelper.show_error("YggStack не запущен")
            return False
        target = self._target_for_tg_bridge()
        if not target:
            if show_errors:
                BulletinHelper.show_error("Выбери Ygg IPv6 proxy")
            self._log_line("telegram bridge target missing")
            return False
        if not self._is_ygg_ipv6_host(target.get("host", "")):
            if show_errors:
                BulletinHelper.show_error("Нужен Ygg IPv6 proxy")
            self._log_line("telegram bridge target is not ygg ipv6: %s" % str(target))
            return False

        preferred_port = int(self._telegram_bridge_port() or DEFAULT_TG_PROXY_BRIDGE_PORT)
        forward_cfg = {
            "id": TG_PROXY_FORWARD_ID,
            "listen_addr": "%s:%d" % (LOCAL_HOST, preferred_port),
            "target_host": str(target.get("host", "") or ""),
            "target_port": int(target.get("port", 0) or 0),
        }
        result = self._stack.open_tcp_forward(forward_cfg)
        if (not bool(result.get("ok"))) and preferred_port != 0:
            forward_cfg["listen_addr"] = "%s:0" % LOCAL_HOST
            result = self._stack.open_tcp_forward(forward_cfg)

        if not bool(result.get("ok")):
            if show_errors:
                BulletinHelper.show_error(str(result.get("message", "Мост не открыт")))
            self._log_line("telegram bridge open failed result=%s" % str(result))
            return False

        local_port = self._listen_port_from_result(result, preferred_port)
        self._set_telegram_bridge_port(local_port)
        if not self._apply_native_proxy_config(target, server_override=LOCAL_HOST, port_override=local_port):
            try:
                self._stack.close_tcp_forward(TG_PROXY_FORWARD_ID)
            except Exception:
                pass
            if show_errors:
                BulletinHelper.show_error("Прокси не применился")
            return False

        self._set_setting_value("telegram_bridge_active", True, reload_settings=False)
        self._log_line("telegram bridge active local=%s:%s target=%s" % (LOCAL_HOST, int(local_port), self._format_proxy_addr(target)))
        if show_errors:
            BulletinHelper.show_success("Мост прокси включен")
        return True

    def _disable_telegram_proxy_bridge(self, restore=True):
        self._log_line("disable telegram bridge restore=%s" % bool(restore))
        current_is_local = self._current_proxy_is_bridge_local()
        saved = self._load_tg_bridge_target()
        try:
            self._stack.close_tcp_forward(TG_PROXY_FORWARD_ID)
        except Exception:
            pass
        self._set_setting_value("telegram_bridge_active", False, reload_settings=False)
        if restore and current_is_local and saved:
            self._apply_native_proxy_config(saved)

    def _on_telegram_bridge_changed(self, enabled):
        val = bool(enabled)
        self.set_setting("telegram_proxy_bridge", val)
        if val:
            self._run_exclusive(self._bridge_native_proxy, True, True)
        else:
            self._disable_telegram_proxy_bridge(restore=True)

    def _rebridge_now(self):
        self._run_exclusive(self._bridge_native_proxy, True, True)

    def _open_tg_proxy_settings(self):
        try:
            from android.content import Intent
            from android.net import Uri

            ctx = ApplicationLoader.applicationContext
            intent = Intent(Intent.ACTION_VIEW, Uri.parse("tg://settings/proxy"))
            intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
            ctx.startActivity(intent)
        except Exception:
            pass

    def _custom_peers_text(self):
        try:
            return str(self.get_setting("custom_peers", "") or "")
        except Exception:
            return ""

    def _custom_peers(self):
        raw = self._custom_peers_text()
        cache = self._custom_peers_cache
        if cache.get("raw") == raw:
            return list(cache.get("parsed", []))
        parsed = _parse_custom_peers_text(raw)
        self._custom_peers_cache = {"raw": raw, "parsed": list(parsed)}
        return list(parsed)

    def _custom_peer_input(self):
        try:
            return str(self.get_setting("peer_input", "") or "").strip()
        except Exception:
            return ""

    def _append_custom_peer_from_input(self):
        raw = self._custom_peer_input()
        peers = _parse_custom_peers_text(raw)
        if not peers:
            BulletinHelper.show_error("Неверный peer")
            return
        existing = self._custom_peers()
        merged = _dedupe_strings(existing + peers)
        added = len(merged) > len(existing)
        self._set_setting_value("custom_peers", "\n".join(merged), reload_settings=False)
        self._set_setting_value("peer_input", "", reload_settings=True)
        BulletinHelper.show_success("Peer добавлен" if added else "Peer уже есть")
        if bool(self.get_setting("enable_stack", False)):
            self._schedule_restart(show_errors=False)

    def _primary_peers(self):
        return _dedupe_strings(list(PRIORITY_BOOTSTRAP_PEERS) + list(self._custom_peers()))

    def _fallback_peers(self, force=False, allow_fetch=True):
        primary_keys = set([str(item or "").strip().lower() for item in self._primary_peers()])
        if allow_fetch:
            fetched = self._fetch_public_peers(force=bool(force))
        elif self._peers_cache:
            fetched = list(self._peers_cache)
        else:
            fetched = list(FALLBACK_PUBLIC_PEERS)
        result = []
        for peer in fetched:
            value = str(peer or "").strip()
            if (not value) or value.lower() in primary_keys:
                continue
            result.append(value)
        return _dedupe_strings(result)

    def _link_local_enabled(self):
        return bool(self.get_setting("enable_link_local", DEFAULT_LINK_LOCAL_ENABLED))

    def _fetch_public_peers(self, force=False):
        now = int(time.time())
        if (not force) and self._peers_cache and (now - int(self._peers_updated_at)) < PEERS_CACHE_TTL_SEC:
            return list(self._peers_cache)

        peers = []
        try:
            peers = _extract_peer_uris(_download_text(PUBLIC_PEERS_URL, timeout=12))
        except Exception:
            peers = []

        if peers:
            self._peers_cache = list(peers)
            self._peers_updated_at = now
            self._save_json_setting("peer_cache", self._peers_cache)
            self.set_setting("peer_cache_ts", str(now))
            return list(peers)

        if self._peers_cache:
            return list(self._peers_cache)
        return list(FALLBACK_PUBLIC_PEERS)

    def _refresh_peers_now(self):
        BulletinHelper.show_info("Обновляю peer-ы...")

        def _worker():
            peers = self._fetch_public_peers(force=True)
            if peers:
                BulletinHelper.show_success("Peer-ы обновлены")
            else:
                BulletinHelper.show_error("Не удалось обновить")

        threading.Thread(target=_worker, daemon=True).start()

    def _libygg_stack_path(self):
        try:
            return os.path.join(self._modules_dir, "libygg_stack.so")
        except Exception:
            return "libygg_stack.so"

    def _has_stack_so(self):
        try:
            path = self._libygg_stack_path()
            return bool(path and os.path.exists(path) and os.path.getsize(path) > 1024)
        except Exception:
            return False

    def _looks_like_elf_so(self, path):
        try:
            with open(path, "rb") as fp:
                head = fp.read(20)
            return bool(head.startswith(b"\x7fELF") and len(head) >= 20 and head[4] == 2 and head[18] == 0xB7)
        except Exception:
            return False

    def _sha256_file(self, path):
        try:
            h = hashlib.sha256()
            with open(path, "rb") as fp:
                while True:
                    chunk = fp.read(65536)
                    if not chunk:
                        break
                    h.update(chunk)
            return h.hexdigest()
        except Exception:
            return ""

    def _reload_stack(self):
        try:
            self._log_line("reload stack from %s" % str(self._libygg_stack_path()))
            self._stack = YggStackNative(self._libygg_stack_path())
            self._log_line("reload stack available=%s" % bool(self._stack.is_available()))
        except Exception:
            self._stack = YggStackNative("")
            self._log_line("reload stack failed", exc=True)

    def _download_stack_so(self, reason="manual", verify_load=False):
        try:
            target = self._libygg_stack_path()
            tmp = target + ".tmp"
            self._log_line("download stack start reason=%s url=%s target=%s" % (str(reason), str(YGG_STACK_URL), str(target)))
            req = urllib.request.Request(YGG_STACK_URL, headers={"User-Agent": "YggStack/0.1"})
            ctx = ssl.create_default_context()
            with urllib.request.urlopen(req, timeout=float(DOWNLOAD_TIMEOUT_SEC), context=ctx) as resp:
                data = resp.read()
                try:
                    headers = dict(resp.headers.items())
                except Exception:
                    headers = {}
            self._log_line("download stack response bytes=%s headers=%s" % (len(data or b""), str(headers)[:800]))
            if not data or len(data) < 1024:
                self.set_setting("stack_last_check_ts", str(int(time.time())))
                return False, "Слишком маленький файл"
            if not data.startswith(b"\x7fELF"):
                self.set_setting("stack_last_check_ts", str(int(time.time())))
                return False, "Это не ELF .so"
            with open(tmp, "wb") as fp:
                fp.write(data)
            if not self._looks_like_elf_so(tmp):
                try:
                    os.remove(tmp)
                except Exception:
                    pass
                self.set_setting("stack_last_check_ts", str(int(time.time())))
                return False, "Не arm64 .so"
            try:
                if os.path.exists(target):
                    os.remove(target)
            except Exception:
                pass
            os.replace(tmp, target)
            sha256 = self._sha256_file(target)
            self.set_setting("stack_last_sha256", sha256)
            self.set_setting("stack_last_size", str(len(data)))
            self.set_setting("stack_last_check_ts", str(int(time.time())))
            self.set_setting("stack_last_update_ts", str(int(time.time())))
            if verify_load:
                self._reload_stack()
                if not self._stack.is_available():
                    return False, "Библиотека скачалась, но не загрузилась"
            return True, ""
        except Exception as exc:
            try:
                if 'tmp' in locals() and os.path.exists(tmp):
                    os.remove(tmp)
            except Exception:
                pass
            self.set_setting("stack_last_check_ts", str(int(time.time())))
            self._log_line("download stack failed", exc=exc)
            return False, str(exc)

    def _stack_update_due(self):
        if not self._has_stack_so():
            return True
        last_check = _safe_int(self.get_setting("stack_last_check_ts", 0), 0)
        if last_check <= 0:
            return True
        return (int(time.time()) - int(last_check)) >= int(CORE_AUTOUPDATE_INTERVAL_SEC)

    def _maybe_auto_update_stack_async(self):
        if not self._stack_update_due():
            return

        def _worker():
            try:
                self._download_stack_so(reason="background_auto", verify_load=False)
            except Exception as exc:
                self._log_line("background stack update failed", exc=exc)

        threading.Thread(target=_worker, daemon=True).start()

    def _ensure_stack_ready(self, show_errors=True, force_update=False):
        if bool(force_update) or self._stack_update_due():
            ok, error_text = self._download_stack_so(reason="startup_auto" if not force_update else "forced_update", verify_load=False)
            if not ok and show_errors:
                BulletinHelper.show_error("Нет ядра: %s" % str(error_text or "ошибка"))
        if not self._stack.is_available() and self._has_stack_so() and self._looks_like_elf_so(self._libygg_stack_path()):
            self._reload_stack()
        if not self._stack.is_available():
            if show_errors:
                BulletinHelper.show_error("libygg_stack.so не загружен")
            return False
        return True

    def _download_stack_now(self, force_update=True):
        BulletinHelper.show_info("Обновляю ядро..." if force_update else "Скачиваю ядро...")

        def _worker():
            ok, error_text = self._download_stack_so(reason="manual_update" if force_update else "manual_download", verify_load=False)
            if ok:
                BulletinHelper.show_success("Ядро обновлено" if force_update else "Ядро скачано")
            else:
                BulletinHelper.show_error("Не скачалось: %s" % str(error_text or "ошибка"))

        threading.Thread(target=_worker, daemon=True).start()

    def _build_stack_config(self, force_peer_refresh=False):
        primary_peers = self._primary_peers()
        fallback_peers = self._fallback_peers(force=bool(force_peer_refresh))
        link_local = bool(self._link_local_enabled())
        return {
            "state_path": str(self._state_file),
            "log_path": str(self._stack_log_file),
            "log_verbose": True,
            "peers": list(primary_peers),
            "primary_peers": list(primary_peers),
            "fallback_peers": list(fallback_peers),
            "bootstrap_wait_ms": int(DEFAULT_BOOTSTRAP_WAIT_MS),
            "shutdown_wait_ms": int(DEFAULT_SHUTDOWN_WAIT_MS),
            "enable_link_local": bool(link_local),
            "node_info": {"name": "YggStack", "plugin": "yggstack"},
            "node_info_privacy": True,
        }

    def _start_stack(self, force_peer_refresh=False, show_errors=True):
        with self._start_lock:
            if self._start_in_progress:
                return False
            self._start_in_progress = True
        try:
            self._log_line("start stack begin force_peer_refresh=%s" % bool(force_peer_refresh))
            if not self._ensure_stack_ready(show_errors=show_errors, force_update=False):
                self._running = False
                self._last_status = {"ok": False, "running": False, "message": "Нет libygg_stack.so"}
                return False
            config = self._build_stack_config(force_peer_refresh=bool(force_peer_refresh))
            result = self._stack.start(config)
            self._last_status = result if isinstance(result, dict) else {"ok": False, "running": False, "message": "bad status"}
            self._running = bool(self._last_status.get("ok")) and bool(self._last_status.get("running"))
            self._log_line("stack start result=%s" % str(self._last_status))
            if self._running:
                if bool(self.get_setting("telegram_proxy_bridge", False)):
                    self._bridge_native_proxy(show_errors=False, ensure_stack=False)
                if show_errors:
                    BulletinHelper.show_success("YggStack включен")
                return True
            if show_errors:
                BulletinHelper.show_error(str(self._last_status.get("message", "Старт не удался")))
            return False
        except Exception as exc:
            self._running = False
            self._last_status = {"ok": False, "running": False, "message": str(exc)}
            self._log_line("start stack crashed", exc=exc)
            if show_errors:
                BulletinHelper.show_error("Краш старта: %s" % str(exc))
            return False
        finally:
            self._start_in_progress = False

    def _ensure_started_async(self, force_peer_refresh=False, show_errors=True):
        threading.Thread(
            target=lambda: self._start_stack(force_peer_refresh=bool(force_peer_refresh), show_errors=bool(show_errors)),
            daemon=True,
        ).start()

    def ensure_running(self, show_errors=True):
        if self._running:
            status = self.stack_status()
            if bool(status.get("running")):
                return True
        return self._start_stack(force_peer_refresh=False, show_errors=bool(show_errors))

    def _run_exclusive(self, fn, *args, **kwargs):
        def _worker():
            with self._worker_lock:
                if self._worker_busy:
                    BulletinHelper.show_info("Операция уже идёт...")
                    return
                self._worker_busy = True
            try:
                fn(*args, **kwargs)
            finally:
                with self._worker_lock:
                    self._worker_busy = False

        threading.Thread(target=_worker, daemon=True).start()

    def _disconnect_stack(self):
        self._log_line("disconnect stack")
        try:
            if bool(self.get_setting("telegram_proxy_bridge", False)) or bool(self.get_setting("telegram_bridge_active", False)):
                self._disable_telegram_proxy_bridge(restore=True)
        except Exception:
            self._log_line("telegram bridge disable failed", exc=True)
        try:
            self._stack.stop(graceful_ms=DEFAULT_SHUTDOWN_WAIT_MS)
        except Exception:
            self._log_line("stack stop failed", exc=True)
        self._running = False
        self._last_status = {"ok": True, "running": False, "message": "stopped"}

    def _schedule_stop(self):
        def _worker():
            BulletinHelper.show_info("YggStack выключается...")
            self._disconnect_stack()
            BulletinHelper.show_success("YggStack выключен")

        threading.Thread(target=_worker, daemon=True).start()

    def _schedule_restart(self, show_errors=True):
        def _worker():
            self._disconnect_stack()
            if bool(self.get_setting("enable_stack", False)):
                self._start_stack(force_peer_refresh=False, show_errors=bool(show_errors))

        threading.Thread(target=_worker, daemon=True).start()

    def _on_enable_changed(self, enabled):
        val = bool(enabled)
        self.set_setting("enable_stack", val)
        if val:
            self._run_exclusive(self._start_stack, False, True)
        else:
            self._schedule_stop()

    def _on_link_local_changed(self, enabled):
        self.set_setting("enable_link_local", bool(enabled))
        if bool(self.get_setting("enable_stack", False)):
            self._schedule_restart(show_errors=True)

    def _restart_now(self):
        self._schedule_restart(show_errors=True)

    def stack_status(self):
        try:
            st = self._stack.status()
            if isinstance(st, dict):
                self._last_status = st
                self._running = bool(st.get("running")) and bool(st.get("ok", True))
                return dict(st)
        except Exception as exc:
            self._log_line("status failed", exc=exc)
        return dict(self._last_status)

    def open_tcp_forward(self, target_host, target_port, listen_host=LOCAL_HOST, listen_port=0, forward_id="", show_errors=True):
        if not self.ensure_running(show_errors=show_errors):
            return {"ok": False, "message": "YggStack не запущен"}
        listen_addr = "%s:%d" % (str(listen_host or LOCAL_HOST), int(listen_port or 0))
        cfg = {
            "id": str(forward_id or ""),
            "listen_addr": listen_addr,
            "target_host": str(target_host or ""),
            "target_port": int(target_port or 0),
        }
        result = self._stack.open_tcp_forward(cfg)
        if show_errors:
            if bool(result.get("ok")):
                BulletinHelper.show_success("Forward открыт")
            else:
                BulletinHelper.show_error(str(result.get("message", "Forward не открыт")))
        return result

    def close_tcp_forward(self, forward_id):
        return self._stack.close_tcp_forward(forward_id)

    def _status_lines(self):
        st = self.stack_status()
        running = bool(st.get("running"))
        ok = bool(st.get("ok", True))
        message = str(st.get("message", "") or "")
        active = _safe_int(st.get("active_peers", 0), 0)
        configured = _safe_int(st.get("configured_peers", 0), 0)
        routes = _safe_int(st.get("routing_entries", 0), 0)
        forwards = _safe_int(st.get("forward_count", 0), 0)
        ipv6 = str(st.get("ipv6", "") or "")
        bridge_enabled = bool(self.get_setting("telegram_proxy_bridge", False))
        bridge_target = self._load_tg_bridge_target()
        bridge_port = int(self._telegram_bridge_port() or 0)
        lines = [
            Text(
                text="Стек включён" if running else "Стек выключен",
                subtext=message[:80] if message and message != "running" else "",
                icon="msg2_proxy_on" if running else "msg2_proxy_off",
            ),
            Text(
                text="Peers: %d/%d" % (int(active), int(configured)),
                icon="msg_link",
            ),
            Text(
                text="Forward'ы: %d" % int(forwards),
                icon="msg_list",
            ),
        ]
        if bridge_enabled:
            sub = ""
            if bridge_target:
                sub = "%s:%d -> %s" % (LOCAL_HOST, int(bridge_port), self._format_proxy_addr(bridge_target))
            lines.append(Text(text="Прокси ExteraGram", subtext=sub[:90], icon="msg_settings"))
        if routes > 0:
            lines.append(Text(text="Маршруты: %d" % int(routes), icon="msg_map"))
        if ipv6:
            lines.append(Text(text="Ygg IP: %s" % ipv6, icon="msg_secret"))
        if not ok and message:
            lines.append(Text(text="Ошибка: %s" % message[:120], icon="msg_warning"))
        return lines

    def create_settings(self):
        enabled = bool(self.get_setting("enable_stack", False))
        bridge_enabled = bool(self.get_setting("telegram_proxy_bridge", False))
        link_local = bool(self._link_local_enabled())
        custom_peer_count = len(self._custom_peers())
        peer_input = self._custom_peer_input()
        has_so = bool(self._has_stack_so())

        items = [
            Header(text="Основное"),
            Switch(
                key="enable_stack",
                text="Включить стек",
                default=bool(enabled),
                icon="msg2_proxy_on" if enabled else "msg2_proxy_off",
                on_change=self._on_enable_changed,
            ),
            Switch(
                key="enable_link_local",
                text="LAN peering",
                default=bool(link_local),
                icon="msg_link",
                on_change=self._on_link_local_changed,
            ),
            Switch(
                key="telegram_proxy_bridge",
                text="Мост прокси",
                default=bool(bridge_enabled),
                icon="msg_settings",
                on_change=self._on_telegram_bridge_changed,
            ),
            Divider(),
            Header(text="Статус"),
        ]
        items.extend(self._status_lines())
        items.extend([
            Divider(),
            Header(text="Свои peer-ы"),
            EditText(
                key="peer_input",
                hint="tcp://host:port",
                default=peer_input,
                multiline=False,
                max_length=600,
            ),
            Text(
                text="Добавить peer",
                subtext="Сохранено: %d" % int(custom_peer_count),
                icon="msg_link",
                on_click=lambda *a: self._append_custom_peer_from_input(),
            ),
            Divider(),
            Header(text="ExteraGram"),
            Text(
                text="Открыть прокси",
                icon="msg_settings",
                on_click=lambda *a: self._open_tg_proxy_settings(),
            ),
            Text(
                text="Обновить мост",
                icon="msg_retry",
                on_click=lambda *a: self._rebridge_now(),
            ),
            Divider(),
            Header(text="API"),
            Text(
                text="Скопировать API",
                subtext="yggstack_client.py",
                icon="msg_link",
                on_click=lambda *a: self._copy_api_hint(),
            ),
            Text(
                text="Перезапустить",
                icon="msg_retry",
                on_click=lambda *a: self._restart_now(),
            ),
            Divider(),
            Header(text="Обслуживание"),
            Text(
                text="Обновить peer-ы",
                icon="msg_retry",
                on_click=lambda *a: self._refresh_peers_now(),
            ),
            Text(
                text="Обновить ядро" if has_so else "Скачать ядро",
                icon="msg_download",
                on_click=lambda *a: self._download_stack_now(force_update=bool(has_so)),
            ),
            Text(
                text="Скопировать логи",
                icon="msg_list",
                on_click=lambda *a: self._copy_logs_to_clipboard(),
            ),
        ])
        return items
